# ---- Binance Testnet -----------------------------------------------
# Create testnet keys at https://testnet.binance.vision/
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET_KEY=your_testnet_secret_key
BINANCE_TESTNET=true

# ---- Anthropic (Claude sentiment scorer) ---------------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# ---- Datastores ----------------------------------------------------
# TimescaleDB (matches docker-compose.yml defaults)
DB_URL=postgres://trader:trader@localhost:5434/trader?sslmode=disable
# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6381/0

# ---- Telegram alerts (optional) ------------------------------------
# Create a bot via @BotFather and grab the chat id with @userinfobot
# Leave blank to disable notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Trading -------------------------------------------------------
# Comma-separated symbols to trade. Default: BTCUSDT only.
# Example: BTCUSDT,ETHUSDT,SOLUSDT
SYMBOLS=BTCUSDT

# Initial portfolio value (USDT). The executor refreshes this from
# the real Binance balance before each trade.
PORTFOLIO_VALUE=10000

# ---- Data retention ------------------------------------------------
# TimescaleDB automatically compresses old chunks and drops data
# beyond the retention window. Trades are never auto-deleted.
# CANDLES_COMPRESS_AFTER=7 days
# CANDLES_RETAIN=60 days
# SIGNALS_COMPRESS_AFTER=7 days
# SIGNALS_RETAIN=180 days
